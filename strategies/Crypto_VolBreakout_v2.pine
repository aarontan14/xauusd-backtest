//@version=5
// =================================================================================
// BTC / ETH Vol-Breakout v2 — entry/exit + vol-targeted sizing + optional ATR stop
//
//   BTC:  dc=10  ma_exit=50  ma_long=100  vol_target=2.5%  lev_cap=3.0  hard_stop=off
//         Backtest 2017-2026: CAGR 79.3%, Sharpe 1.54, MaxDD -42%, Calmar 1.88
//
//   ETH:  dc=30  ma_exit=50  ma_long=150  vol_target=3.0%  lev_cap=2.0  hard_stop=3*ATR
//         Backtest 2017-2026: CAGR 51.6%, Sharpe 1.14, MaxDD -39%, Calmar 1.31
//
// On a SPOT account, set lev_cap = 1.0 (still cuts DD ~40%). On margin/perp, 2-3x ok.
// Apply on: BINANCE:BTCUSDT / BYBIT:BTCUSDT / BINANCE:ETHUSDT etc., DAILY timeframe.
// =================================================================================
strategy("Crypto VolBreakout v2",
     overlay = true, pyramiding = 0, initial_capital = 100000,
     default_qty_type    = strategy.cash,
     default_qty_value   = 100000,                  // dummy; we override in entry()
     commission_type     = strategy.commission.percent,
     commission_value    = 0.05,
     slippage            = 5,
     calc_on_every_tick  = false,
     process_orders_on_close = false)

// ---- Inputs ----
preset      = input.string("BTC", "Asset preset", options=["BTC","ETH","Custom"])
useHardStop = input.bool(true,  "Use hard ATR stop (recommended for ETH)")
isSpot      = input.bool(false, "Spot-only account (caps leverage at 1.0x)")

// Asset-specific defaults
defDc       = preset == "BTC" ? 10  : preset == "ETH" ? 30  : 20
defMaExit   = preset == "BTC" ? 50  : preset == "ETH" ? 50  : 50
defMaLong   = preset == "BTC" ? 100 : preset == "ETH" ? 150 : 200
defVolTgt   = preset == "BTC" ? 0.025 : preset == "ETH" ? 0.030 : 0.025
defLevCap   = preset == "BTC" ? 3.0   : preset == "ETH" ? 2.0   : 2.0
defHardK    = preset == "BTC" ? 0.0   : preset == "ETH" ? 3.0   : 3.0  // 0 = off

dcLen     = input.int(defDc,     "Donchian length",   minval=2)
maExit    = input.int(defMaExit, "Exit MA length",    minval=5)
maLong    = input.int(defMaLong, "Long-term MA",      minval=20)
volTarget = input.float(defVolTgt,"Daily vol target",  step=0.005, minval=0.005)
levCap    = input.float(defLevCap,"Leverage cap",      step=0.5,   minval=0.5)
hardK     = input.float(defHardK, "Hard stop (k*ATR, 0=off)", step=0.5, minval=0.0)

// Override leverage if user toggled spot
levCapEff = isSpot ? math.min(levCap, 1.0) : levCap
hardOn    = useHardStop and hardK > 0

// ---- Indicators ----
dcHi    = ta.highest(high, dcLen)[1]
maExitV = ta.sma(close, maExit)
maLongV = ta.sma(close, maLong)
atr14   = ta.atr(14)
ret1    = ta.change(close) / close[1]
rvol    = ta.stdev(ret1, 20)              // 20-day daily-return std

bullRegime = close > maLongV
entrySig = (close >= dcHi) and bullRegime
exitSig  = close < maExitV

// Vol-targeted size as fraction of equity (capped at levCapEff)
sizeFrac = na(rvol) or rvol == 0 ? levCapEff : math.min(volTarget / rvol, levCapEff)

// ---- Orders ----
if entrySig and strategy.position_size == 0
    cashAmt = strategy.equity * sizeFrac
    qty = cashAmt / close
    strategy.entry("Long", strategy.long, qty=qty,
        alert_message='{"action":"buy","symbol":"{{ticker}}","preset":"' + preset + '","price":"{{close}}","size_frac":"' + str.tostring(sizeFrac, "0.000") + '"}')

if strategy.position_size > 0
    if exitSig
        strategy.close("Long", comment="signal_exit",
            alert_message='{"action":"sell","symbol":"{{ticker}}","preset":"' + preset + '","reason":"signal","price":"{{close}}"}')
    if hardOn
        stopPx = strategy.position_avg_price - hardK * atr14
        strategy.exit("HardStop", from_entry="Long", stop=stopPx,
            alert_message='{"action":"sell","symbol":"{{ticker}}","preset":"' + preset + '","reason":"stop","price":"{{close}}"}')

// ---- Visuals ----
plot(dcHi,    "Donchian high", color=color.new(color.aqua, 0))
plot(maExitV, "Exit MA",       color=color.new(color.orange, 0))
plot(maLongV, "Long MA",       color=color.new(color.gray, 0), linewidth=2)
bgcolor(bullRegime ? color.new(color.green, 92) : na, title="Bull regime")
plotshape(entrySig and strategy.position_size == 0, "Entry", shape.triangleup,
     location.belowbar, color.new(color.lime, 0), size=size.small)
plotshape(exitSig and strategy.position_size > 0,  "Exit",  shape.triangledown,
     location.abovebar, color.new(color.red, 0),  size=size.small)
plot(strategy.position_size > 0 and hardOn ? strategy.position_avg_price - hardK * atr14 : na,
     "Hard stop", color=color.new(color.red, 0), style=plot.style_linebr)

// Show realized vol & sizing in info table
var table tbl = table.new(position.top_right, 2, 4, border_width=1)
if barstate.islast
    table.cell(tbl, 0, 0, "Real. vol (20d)", bgcolor=color.gray, text_color=color.white)
    table.cell(tbl, 1, 0, str.tostring(rvol*100, "0.00") + "%")
    table.cell(tbl, 0, 1, "Size frac",       bgcolor=color.gray, text_color=color.white)
    table.cell(tbl, 1, 1, str.tostring(sizeFrac, "0.000"))
    table.cell(tbl, 0, 2, "Lev cap",         bgcolor=color.gray, text_color=color.white)
    table.cell(tbl, 1, 2, str.tostring(levCapEff, "0.0"))
    table.cell(tbl, 0, 3, "Bull regime",     bgcolor=color.gray, text_color=color.white)
    table.cell(tbl, 1, 3, bullRegime ? "YES" : "NO")

// ---- Alerts ----
alertcondition(entrySig and strategy.position_size == 0,
     "Entry alert",
     '{"action":"buy","symbol":"{{ticker}}","preset":"' + preset + '","price":"{{close}}","time":"{{timenow}}"}')
alertcondition(exitSig and strategy.position_size > 0,
     "Exit alert",
     '{"action":"sell","symbol":"{{ticker}}","preset":"' + preset + '","price":"{{close}}","time":"{{timenow}}"}')
